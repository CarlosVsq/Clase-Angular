# Copia este archivo como .env y completa los valores.

# Login con Google (ID de cliente OAuth de la app)
GOOGLE_CLIENT_ID=

# Credenciales para el envío de Email (Gmail API + OAuth2, desde OAuth Playground)
EMAIL_CLIENT_ID=
EMAIL_CLIENT_SECRET=
EMAIL_REDIRECT_URI=https://developers.google.com/oauthplayground
EMAIL_REFRESH_TOKEN=

# Cuenta Gmail remitente de los correos
EMAIL_USER=

# Configuración de la base de datos MySQL
DB_HOST=localhost
DB_USER=root
DB_PASSWORD=
DB_NAME=proyecto-angular-db

# Puerto del servidor Express
PORT=3000
